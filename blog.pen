                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "O TanStack Start oferece uma experiência de desenvolvimento excepcional com type-safety de ponta a ponta, SSR otimizado e roteamento baseado em arquivos. Combinado com o Bun, temos um stack extremamente rápido.",
                  "lineHeight": 1.8,
                  "fontFamily": "$font-body",
                  "fontSize": 16,
                  "fontWeight": "normal"
