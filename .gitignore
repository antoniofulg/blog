# Playwright / e2e
tests/e2e/.auth/
tests/e2e/storageState.json
test-results/
playwright-report/
coverage/

# macOS tmpdir leak guard (writes via path.join + absolute tmpdir)
var/

# Content audit per-run reports (gitignored; uploaded as GHA artifact)
docs/_reports/content-audit-*.md

# App audit per-run reports (gitignored; uploaded as GHA artifact)
docs/_reports/app-audit-*.md

# Lighthouse CI flags + per-run artifacts (transient; not for repo)
.lighthouseci/

# Compozy workflow artifacts (PRD/TechSpec/tasks/reviews) — local-only
.compozy/

# Auto-generated OG cards (written by `bun run sync` to public/og/<locale>/<slug>.png).
# Ignore only the per-locale subdirectories so the generated cards stay out of
# git, while author-supplied custom covers placed directly in public/og/
# (e.g. coverImage: /og/custom-cover.png, per CONTENT.md) remain tracked and
# ship in the deploy artifact.
public/og/*/

# Agent worktrees created by sub-agent dispatch hook — transient
.worktrees/

# Local Claude Code preview launch config — user-specific
.claude/launch.json
